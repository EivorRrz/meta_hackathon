# Copy to ".env" in the same folder as inference.py, then fill in secrets.
# inference.py loads .env automatically when python-dotenv is installed (pip install -e .).

# =============================================================================
# LLM (OpenAI-compatible Chat Completions)
# =============================================================================
# Priority: HF_TOKEN > OPENAI_API_KEY > API_KEY
HF_TOKEN=
# OPENAI_API_KEY=
# API_KEY=

# Base URL for chat.completions (examples below)
API_BASE_URL=https://router.huggingface.co/v1
# API_BASE_URL=https://api.openai.com/v1

MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
# MODEL_NAME=gpt-4o-mini

# =============================================================================
# OpenEnv server (WebSocket client)
# =============================================================================
# Public Hugging Face Space or local uvicorn
OPENENV_BASE_URL=http://127.0.0.1:8000
# OPENENV_BASE_URL=https://YOUR_USERNAME-YOUR_SPACE.hf.space

# Optional: run env from Docker image instead of OPENENV_BASE_URL
# IMAGE_NAME=support-openenv:latest
# LOCAL_IMAGE_NAME=

# =============================================================================
# Which tasks to run (baseline)
# =============================================================================
# Leave empty to run all three tasks (support_classify, support_routing, support_resolution).
# Set ONE id for a single episode (matches some harnesses that expect one START/END per run).
# SUPPORT_ENV_TASK=support_classify
# TASK_NAME=support_classify

# Printed in [START] line
SUPPORT_ENV_BENCHMARK=customer_support_env

# =============================================================================
# Model / loop tuning
# =============================================================================
SUPPORT_ENV_MAX_STEPS=8
SUPPORT_ENV_TEMPERATURE=0.2
SUPPORT_ENV_MAX_TOKENS=240
SUPPORT_ENV_SUCCESS_THRESHOLD=0.25
